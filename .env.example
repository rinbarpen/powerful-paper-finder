# arXiv Paper Finder — Environment Configuration
# Copy to .env and fill in your keys

# GPT-5.5 (vvveai or other OpenAI-compatible provider)
OPENAI_BASE_URL=https://api.vveai.com/v1
OPENAI_API_KEY=sk-your-key

# DeepSeek-V4-Pro (vvveai or other OpenAI-compatible provider)
DEEPSEEK_BASE_URL=https://api.vveai.com/v1
DEEPSEEK_API_KEY=sk-your-key

# OpenRouter (for free/cheap filter model)
OPENROUTER_API_KEY=sk-or-your-key

# Semantic Scholar (optional — improves rate limit from 100/5min to 100/sec)
SEMANTIC_SCHOLAR_API_KEY=your-ss-key
